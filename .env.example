# Mission Control Environment Variables
# Copy this to .env.local and fill in your values

# ---------------------------------------------------------------------------
# DATABASE — Required for persistence
# ---------------------------------------------------------------------------

# Option 1: Use Turso Cloud Database (recommended for production)
# Get a free database at https://turso.tech
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Option 2: Use local SQLite (default if Turso not configured)
# No configuration needed — will use data/mission-control.db

# Legacy aliases (also supported)
# DATABASE_URL=libsql://your-database.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# ---------------------------------------------------------------------------
# SECURITY — Required for production webhooks
# ---------------------------------------------------------------------------

# Shared secret for incoming webhooks from OpenClaw AI agent
# In dev mode (no secret set), all webhooks are accepted
WEBHOOK_SECRET=your-webhook-secret

# ---------------------------------------------------------------------------
# INTEGRATIONS — Required for live demo features
# ---------------------------------------------------------------------------

# Where to POST the Revenue Planner payload when LOCK & BUILD fires
OPENCLAW_WEBHOOK_URL=https://your-openclaw-endpoint.com/webhook

# GoHighLevel API key
GHL_API_KEY=pit-xxx
GHL_LOCATION_ID=xxx

# Stripe secret key for revenue tracking
STRIPE_SECRET_KEY=sk_live_xxx

# ---------------------------------------------------------------------------
# OPTIONAL — Features degrade gracefully without these
# ---------------------------------------------------------------------------

# Google Drive folder ID for AIM-DEMO-BRAIN
GOOGLE_DRIVE_BRAIN_FOLDER_ID=your-folder-id

# Public URL of this dashboard (for self-ping health check)
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# Optional: Password protect your dashboard
MISSION_CONTROL_PASSWORD=your-password
